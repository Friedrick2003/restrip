# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/restrip
# Local:  mongodb://127.0.0.1:27017/restrip
MONGO_URI=mongodb://127.0.0.1:27017/restrip

# ── JWT ───────────────────────────────────────────────
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_this_to_a_long_random_secret_access
JWT_REFRESH_SECRET=change_this_to_a_long_random_secret_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Frontend URL (CORS) ───────────────────────────────
CLIENT_URL=http://localhost:3000
